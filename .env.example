# AeroClass Environment Configuration
# Copy this file to .env and update values for your environment

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=AeroClass API
API_VERSION=0.1.0

# CORS Configuration
# For development: CORS_ORIGINS=*
# For production: CORS_ORIGINS=https://yourusername.pythonanywhere.com
CORS_ORIGINS=*

# File Storage
# For development: UPLOAD_DIR=uploads
# For PythonAnywhere: UPLOAD_DIR=/var/www/your_username_pythonanywhere_com/uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100
MAX_TRIANGLES=1000000

# UI Configuration
UI_PATH=UI_test

# Physics Engine
PHYSICS_ENGINE_PATH=physics_engine
